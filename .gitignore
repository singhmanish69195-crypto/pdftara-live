# ==========================================
# SUPER WHITELIST: SRC FOLDER KO KABHI MAT ROKNA
# ==========================================
!src/
!src/**

# Dependencies
node_modules
.pnp
.pnp.js

# Build output (Global ignores)
.next
out

# Note: Humne upar 'src' ko whitelist kar diya hai, 
# toh ab 'src' ke andar wala 'build' ya 'dist' kabhi ignore nahi hoga.
# Lekin root level par 'build' ko ignore rakhna safety ke liye sahi hai.
build
dist

# ==========================================
# PUBLIC ASSETS: Inhe GitHub par bhejney ke liye 
# ==========================================
!public/pdfjs-annotation-viewer/build/
!public/pdfjs-viewer/build/
!public/workers/

# Testing
coverage

# Misc
.DS_Store
*.pem
Thumbs.db

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local env files (Inhe hamesha ignore rakhna chahiye)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# IDE / Editor
.idea
.vscode
.agent
.kiro
*.swp
*.swo
*~

